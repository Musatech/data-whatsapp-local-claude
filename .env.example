# ============================================================
# WhatsApp Local Claude - Configuração
# Copie este arquivo para .env e ajuste os valores
# ============================================================

# Diretório onde os dados serão armazenados (mensagens, mídia, DB)
DATA_DIR=./data

# Caminho para o banco de dados SQLite de mensagens
MESSAGES_DB=./data/messages.db

# Caminho para o banco de dados SQLite da sessão WhatsApp (gerado automaticamente)
SESSION_DB=./data/whatsapp-session.db

# Diretório para arquivos de mídia (áudios, imagens, etc.)
MEDIA_DIR=./data/media

# Modelo Whisper para transcrição de áudios
# Opções: tiny, base, small, medium, large
# tiny/base = mais rápido, menos preciso
# medium/large = mais lento, mais preciso
# Recomendado: small (bom equilíbrio velocidade/precisão)
WHISPER_MODEL=small

# Idioma padrão para transcrição (deixe vazio para detecção automática)
# Exemplos: pt, en, es
WHISPER_LANGUAGE=pt

# Número máximo de mensagens retornadas por padrão
DEFAULT_MESSAGE_LIMIT=50

# Número máximo de conversas listadas por padrão
DEFAULT_CHAT_LIMIT=20

# Habilitar download automático de áudios para transcrição (true/false)
AUTO_DOWNLOAD_AUDIO=true

# Habilitar download automático de imagens (true/false)
AUTO_DOWNLOAD_IMAGES=false

# Nível de log: debug, info, warn, error
LOG_LEVEL=info
